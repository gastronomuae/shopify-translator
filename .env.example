# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Shopify Translations API (optional) ───────────────────────────────────
# Required to use the Sync / Push buttons in the product editor.
# Create a private app (or custom app) with the "Translations" access scope.

# Your store's .myshopify.com domain (without https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API access token from the custom app
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...

# Target locale to push translations into (default: en)
SHOPIFY_TARGET_LOCALE=en

# Set to "1" to show Sync / Push buttons in the editor UI
NEXT_PUBLIC_SHOPIFY_ENABLED=1
